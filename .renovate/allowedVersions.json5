{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      matchDatasources: ["docker"],
      matchPackagePatterns: ["postgresql"],
      allowedVersion: "<17"
    },
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["/crunchy-postgres-vectorchord/"],
      matchUpdateTypes: ["major"],
      enabled: false
    }
  ]
}
