{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      matchDatasources: ["docker"],
      matchPackagePatterns: ["postgresql"],
      allowedVersion: "<17"
    },
    {
      matchDatasources: ["docker"],
      matchPackagePatterns: ["crunchy-postgres-vectorchord"],
      allowedVersion: "/^16/"
    }
  ]
}
